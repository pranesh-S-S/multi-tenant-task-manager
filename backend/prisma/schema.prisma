// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN
  MEMBER
}



enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityAction {
  // Task actions
  CREATE_TASK
  UPDATE_TASK
  DELETE_TASK
  RESTORE_TASK
  ASSIGN_TASK

  // User actions
  CREATE_USER
  UPDATE_USER
  DEACTIVATE_USER

  // Organization actions
  UPDATE_ORGANIZATION

  // Auth actions
  USER_LOGIN
  USER_LOGOUT
}

enum EntityType {
  TASK
  USER
  ORGANIZATION
}

// ============================================================================
// MODELS
// ============================================================================

/// Tenant entity. All data is scoped to an organization.
model Organization {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  tasks        Task[]
  activityLogs ActivityLog[]

  @@map("organizations")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

/// User belongs to exactly one organization.
/// Email is globally unique (simplifies auth — one account per email).
model User {
  id             String       @id @default(uuid())
  email          String       @unique @db.VarChar(255)
  password       String?      /// bcrypt hashed, optional for OAuth users
  authProvider   AuthProvider @default(LOCAL) @map("auth_provider")
  googleId       String?      @unique @map("google_id")
  firstName      String       @map("first_name") @db.VarChar(100)
  lastName       String       @map("last_name") @db.VarChar(100)
  role           Role         @default(MEMBER)
  jobTitle       String?      @map("job_title") @db.VarChar(100)
  organizationId String       @map("organization_id")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdTasks  Task[]         @relation("TaskCreator")
  assignedTasks Task[]         @relation("TaskAssignees")
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]

  // Indexes
  @@index([organizationId])
  @@index([email])
  @@index([googleId])
  @@index([organizationId, role])
  @@map("users")
}

/// Task belongs to an organization. Supports soft delete.
model Task {
  id             String       @id @default(uuid())
  title          String       @db.VarChar(255)
  description    String?      @db.Text
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?    @map("due_date")
  organizationId String       @map("organization_id")
  createdById    String       @map("created_by_id")
  isDeleted      Boolean      @default(false) @map("is_deleted")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignees    User[]       @relation("TaskAssignees")

  // Indexes — designed based on expected query patterns
  @@index([organizationId])
  @@index([createdById])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([organizationId, isDeleted])
  @@index([organizationId, status, isDeleted])
  @@index([organizationId, dueDate])
  @@index([organizationId, createdById])
  @@unique([organizationId, title])
  @@map("tasks")
}

/// Immutable audit log. NEVER updated or deleted.
model ActivityLog {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  action         ActivityAction
  entityType     EntityType     @map("entity_type")
  entityId       String         @map("entity_id")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@map("activity_logs")
}

/// Refresh token for JWT rotation. Stored hashed, never as plaintext.
/// Includes device info for session awareness ("logged in devices" UI).
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  device    String?  @db.VarChar(255)              /// e.g., "Chrome on Windows"
  ipAddress String?  @map("ip_address") @db.VarChar(45) /// IPv4 or IPv6
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])                                  // Find all tokens for a user
  @@index([token])                                   // Lookup by hashed token
  @@index([expiresAt])                               // Cleanup expired tokens
  @@index([userId, isRevoked])                       // Active sessions per user
  @@map("refresh_tokens")
}
