# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskmanager?schema=public"

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Cookie Domain (optional — for subdomain deployments, e.g., '.yourdomain.com')
# COOKIE_DOMAIN=
